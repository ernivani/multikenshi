<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Color resources -->
  <Style Selector=":is(Window)">
    <Style.Resources>
      <Color x:Key="ColBackground">#0F0F0F</Color>
      <Color x:Key="ColSidebar">#0E0E0E</Color>
      <Color x:Key="ColSurface">#1a1a1a</Color>
      <Color x:Key="ColSurface2">#222222</Color>
      <Color x:Key="ColBorder">#262626</Color>
      <Color x:Key="ColBorder2">#303030</Color>
      <Color x:Key="ColAccent">#c8a052</Color>
      <Color x:Key="ColAccentDim">#7a5c28</Color>
      <Color x:Key="ColAccentLight">#e0c070</Color>
      <Color x:Key="ColText1">#F0F0F0</Color>
      <Color x:Key="ColText2">#6b6b6b</Color>
      <Color x:Key="ColText3">#3a3a3a</Color>
      <Color x:Key="ColGreen">#4a9e6a</Color>
      <Color x:Key="ColRed">#9a3a3a</Color>
      <Color x:Key="ColYellow">#8a6a28</Color>

      <SolidColorBrush x:Key="BrBackground" Color="#0F0F0F" />
      <SolidColorBrush x:Key="BrSidebar" Color="#0E0E0E" />
      <SolidColorBrush x:Key="BrSurface" Color="#1a1a1a" />
      <SolidColorBrush x:Key="BrSurface2" Color="#222222" />
      <SolidColorBrush x:Key="BrBorder" Color="#262626" />
      <SolidColorBrush x:Key="BrBorder2" Color="#303030" />
      <SolidColorBrush x:Key="BrAccent" Color="#c8a052" />
      <SolidColorBrush x:Key="BrAccentDim" Color="#7a5c28" />
      <SolidColorBrush x:Key="BrAccentLight" Color="#e0c070" />
      <SolidColorBrush x:Key="BrText1" Color="#F0F0F0" />
      <SolidColorBrush x:Key="BrText2" Color="#6b6b6b" />
      <SolidColorBrush x:Key="BrText3" Color="#3a3a3a" />
      <SolidColorBrush x:Key="BrGreen" Color="#4a9e6a" />
      <SolidColorBrush x:Key="BrRed" Color="#9a3a3a" />
      <SolidColorBrush x:Key="BrYellow" Color="#8a6a28" />
      <SolidColorBrush x:Key="BrDarkText" Color="#0F0F0F" />
    </Style.Resources>
  </Style>

  <!-- TextBox dark styling -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="#222222" />
    <Setter Property="Foreground" Value="#F0F0F0" />
    <Setter Property="BorderBrush" Value="#262626" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="CaretBrush" Value="#F0F0F0" />
    <Setter Property="SelectionBrush" Value="#c8a052" />
    <Setter Property="SelectionForegroundBrush" Value="#0F0F0F" />
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="#c8a052" />
  </Style>
  <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#282828" />
  </Style>

  <!-- Accent button (filled) -->
  <Style Selector="Button.accent">
    <Setter Property="Background" Value="#c8a052" />
    <Setter Property="Foreground" Value="#0F0F0F" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#e0c070" />
    <Setter Property="Foreground" Value="#0F0F0F" />
  </Style>
  <Style Selector="Button.accent:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#a88030" />
  </Style>

  <!-- Accent outline button (gold border, transparent bg) -->
  <Style Selector="Button.accent-outline">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#c8a052" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="BorderBrush" Value="#7a5c28" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.accent-outline:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1a1508" />
    <Setter Property="BorderBrush" Value="#c8a052" />
  </Style>
  <Style Selector="Button.accent-outline:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#221c0a" />
  </Style>

  <!-- Ghost button (outline) -->
  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#6b6b6b" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="BorderBrush" Value="#303030" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1a1a1a" />
  </Style>
  <Style Selector="Button.ghost:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#222222" />
  </Style>

  <!-- Danger button (red tint) -->
  <Style Selector="Button.danger">
    <Setter Property="Background" Value="#2a1414" />
    <Setter Property="Foreground" Value="#9a3a3a" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#3a1a1a" />
  </Style>
  <Style Selector="Button.danger:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#200e0e" />
  </Style>

  <!-- Surface button (browse, etc) -->
  <Style Selector="Button.surface">
    <Setter Property="Background" Value="#222222" />
    <Setter Property="Foreground" Value="#F0F0F0" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="BorderBrush" Value="#303030" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.surface:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#2a2a2a" />
  </Style>

  <!-- Modal close button -->
  <Style Selector="Button.modal-close">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#6b6b6b" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.modal-close:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#222222" />
    <Setter Property="Foreground" Value="#F0F0F0" />
  </Style>

  <!-- Disabled buttons -->
  <Style Selector="Button.accent:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="#222222" />
    <Setter Property="Foreground" Value="#3a3a3a" />
  </Style>
  <Style Selector="Button.ghost:disabled">
    <Setter Property="Opacity" Value="0.25" />
  </Style>

  <!-- Nav button -->
  <Style Selector="Button.nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#6E6E6E" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#191919" />
    <Setter Property="Foreground" Value="#B4B4B4" />
  </Style>
  <Style Selector="Button.nav.active">
    <Setter Property="Background" Value="#202020" />
    <Setter Property="Foreground" Value="#F0F0F0" />
  </Style>
  <Style Selector="Button.nav.active /template/ ContentPresenter">
    <Setter Property="Background" Value="#202020" />
    <Setter Property="Foreground" Value="#F0F0F0" />
  </Style>

  <!-- Windows-style caption buttons -->
  <Style Selector="Button.caption-btn">
    <Setter Property="Width" Value="46" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#999999" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.caption-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#2a2a2a" />
    <Setter Property="Foreground" Value="#F0F0F0" />
  </Style>
  <Style Selector="Button.caption-btn.close:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#c42b1c" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <!-- ScrollViewer dark scrollbar -->
  <Style Selector="ScrollViewer">
    <Setter Property="AllowAutoHide" Value="True" />
  </Style>
</Styles>
