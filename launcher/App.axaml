<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KenshiLauncher.ViewModels"
             xmlns:views="using:KenshiLauncher.Views"
             x:Class="KenshiLauncher.App">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://KenshiLauncher/Themes/KenshiTheme.axaml" />
  </Application.Styles>

  <Application.DataTemplates>
    <DataTemplate DataType="{x:Type vm:PlayViewModel}">
      <views:PlayView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
      <views:SettingsView />
    </DataTemplate>
  </Application.DataTemplates>
</Application>
