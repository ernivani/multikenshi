<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KenshiLauncher.ViewModels"
             xmlns:views="using:KenshiLauncher.Views"
             x:Class="KenshiLauncher.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
        <ColorPaletteResources x:Key="Dark"
            Accent="#c8a052" />
      </FluentTheme.Palettes>
    </FluentTheme>
    <StyleInclude Source="avares://KenshiLauncher/Themes/KenshiTheme.axaml" />
  </Application.Styles>

  <Application.DataTemplates>
    <DataTemplate DataType="{x:Type vm:PlayViewModel}">
      <views:PlayView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
      <views:SettingsView />
    </DataTemplate>
  </Application.DataTemplates>
</Application>
