<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KenshiLauncher.ViewModels"
        x:Class="KenshiLauncher.Views.HostWindow"
        x:DataType="vm:HostViewModel"
        Title="Kenshi Multi — Server"
        Width="620" Height="560"
        MinWidth="400" MinHeight="300"
        Background="#0F0F0F"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="36"
        SystemDecorations="Full">

  <Grid RowDefinitions="36,*">
    <!-- Titlebar -->
    <Border Grid.Row="0" Background="#1a1a1a"
            BorderBrush="#262626" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <Border Grid.Column="0" Background="Transparent"
                PointerPressed="TitleBar_PointerPressed">
          <TextBlock Text="Server" FontSize="11" Foreground="#3a3a3a"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsHitTestVisible="False" />
        </Border>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Classes="caption-btn close" Click="OnClose" ToolTip.Tip="Stop &amp; Close">
            <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{Binding $parent[Button].Foreground}"
                  StrokeThickness="1" Width="10" Height="10"
                  Stretch="Uniform" StrokeLineCap="Round"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Content -->
    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,1,*,Auto">

      <!-- Status bar -->
      <Border Grid.Row="0" Background="#1a1a1a" Padding="16,10">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
            <Ellipse Name="StatusDot" Width="7" Height="7" VerticalAlignment="Center" />
            <TextBlock Name="StatusText" FontSize="12" Foreground="#F0F0F0" VerticalAlignment="Center" />
            <Border Background="#222222" CornerRadius="8" Padding="7,2" Margin="6,0,0,0"
                    VerticalAlignment="Center">
              <TextBlock FontSize="10" Foreground="#6b6b6b" VerticalAlignment="Center">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0} players">
                    <Binding Path="PlayerCount" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
            </Border>
            <!-- Save name badge -->
            <Border Background="#1a1508" CornerRadius="8" Padding="7,2" Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    IsVisible="{Binding LoadedSaveName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="{Binding LoadedSaveName}" FontSize="10" Foreground="#c8a052"
                         VerticalAlignment="Center" />
            </Border>
            <!-- Last saved indicator -->
            <TextBlock Text="{Binding LastSavedText}" FontSize="10" Foreground="#3a3a3a"
                       VerticalAlignment="Center" Margin="6,0,0,0"
                       IsVisible="{Binding LastSavedText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          </StackPanel>
          <Button Grid.Column="1" Classes="danger" Height="26" Padding="12,0" FontSize="11"
                  Content="Stop" VerticalContentAlignment="Center"
                  Command="{Binding ToggleServerCommand}"
                  IsVisible="{Binding IsRunning}" />
        </Grid>
      </Border>

      <!-- Player cards -->
      <Border Grid.Row="1" Padding="0,0,0,0" MaxHeight="280">
        <DockPanel>
          <!-- Player list header -->
          <Border DockPanel.Dock="Top" Padding="16,6" BorderBrush="#262626" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Players" FontSize="11" FontWeight="Medium"
                         Foreground="#6b6b6b" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="ghost" Height="22" Padding="8,0" FontSize="10"
                      Content="Clear registry" VerticalContentAlignment="Center"
                      Foreground="#3a3a3a"
                      Command="{Binding ClearPlayersCommand}"
                      IsVisible="{Binding ActiveSaveFolderName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </Grid>
          </Border>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding PlayerCards}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PlayerCardViewModel">
                  <Border BorderBrush="#262626" BorderThickness="0,0,0,1" Padding="0">
                    <StackPanel>
                      <!-- Card header (clickable to expand) -->
                      <Border Padding="16,8" Background="#141414" Cursor="Hand"
                              PointerPressed="PlayerCard_PointerPressed"
                              Tag="{Binding}">
                        <Grid ColumnDefinitions="*,Auto">
                          <StackPanel Grid.Column="0" Spacing="3">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <!-- Player name -->
                              <TextBlock Text="{Binding HeaderText}" FontSize="12"
                                         FontWeight="SemiBold" Foreground="#F0F0F0" />
                              <!-- Host badge -->
                              <Border Background="#1a2010" CornerRadius="4" Padding="5,1"
                                      IsVisible="{Binding IsHost}" VerticalAlignment="Center">
                                <TextBlock Text="HOST" FontSize="9" Foreground="#7ab648"
                                           VerticalAlignment="Center" />
                              </Border>
                            </StackPanel>
                            <!-- Faction + Position row -->
                            <StackPanel Orientation="Horizontal" Spacing="10">
                              <TextBlock FontSize="10" Foreground="#6b6b6b">
                                <TextBlock.Text>
                                  <MultiBinding StringFormat="{}{0}  |  {1}">
                                    <Binding Path="Faction" />
                                    <Binding Path="Position" />
                                  </MultiBinding>
                                </TextBlock.Text>
                              </TextBlock>
                            </StackPanel>
                          </StackPanel>
                          <!-- Squad count badge -->
                          <Border Grid.Column="1" Background="#1a1a1a" CornerRadius="8"
                                  Padding="8,2" VerticalAlignment="Center">
                            <TextBlock FontSize="10" Foreground="#6b6b6b">
                              <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} squad">
                                  <Binding Path="SquadCount" />
                                </MultiBinding>
                              </TextBlock.Text>
                            </TextBlock>
                          </Border>
                        </Grid>
                      </Border>

                      <!-- Expanded squad list -->
                      <ItemsControl ItemsSource="{Binding SquadMembers}"
                                    IsVisible="{Binding IsExpanded}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SquadMemberViewModel">
                            <Border Padding="28,3,16,3" Background="#0F0F0F">
                              <Grid ColumnDefinitions="12,*,Auto">
                                <TextBlock Grid.Column="0" Text="·" FontSize="11"
                                           Foreground="#3a3a3a" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="10"
                                           Foreground="#a0a0a0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding Position}" FontSize="10"
                                           Foreground="#3a3a3a" VerticalAlignment="Center" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- Divider -->
      <Border Grid.Row="2" Background="#262626" />

      <!-- Log panel -->
      <ScrollViewer Grid.Row="3" Name="LogScroller"
                    VerticalScrollBarVisibility="Auto"
                    Padding="0">
        <ItemsControl Name="LogItems" ItemsSource="{Binding ServerLog}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas,Courier New,monospace"
                         Foreground="#6b6b6b" Padding="16,2" TextWrapping="Wrap" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Command bar -->
      <Border Grid.Row="4" Background="#1a1a1a" BorderBrush="#262626" BorderThickness="0,1,0,0"
              Padding="12,8">
        <Grid ColumnDefinitions="*,8,Auto">
          <TextBox Grid.Column="0" Text="{Binding CommandText}"
                   Watermark="Type a command... (/help for list)"
                   FontSize="12" FontFamily="Consolas,Courier New,monospace"
                   Padding="10,6" Height="30"
                   Background="#0f0f0f"
                   Name="CommandInput"
                   KeyDown="CommandInput_KeyDown" />
          <Button Grid.Column="2" Classes="accent" Height="30" Padding="14,0" FontSize="11"
                  Content="Send" VerticalContentAlignment="Center"
                  Command="{Binding SendCommandCommand}" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
