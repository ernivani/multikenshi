<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KenshiLauncher.ViewModels"
        x:Class="KenshiLauncher.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Kenshi Multi"
        Width="960" Height="680"
        MinWidth="800" MinHeight="500"
        Background="#0F0F0F"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="36"
        SystemDecorations="Full">

  <Grid RowDefinitions="36,*">
    <!-- Titlebar (draggable) -->
    <Border Grid.Row="0" Background="#1a1a1a"
            BorderBrush="#262626" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <!-- Drag region -->
        <Border Grid.Column="0" Background="Transparent"
                PointerPressed="TitleBar_PointerPressed"
                DoubleTapped="TitleBar_DoubleTapped">
          <TextBlock Text="Kenshi Multi" FontSize="11" Foreground="#3a3a3a"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsHitTestVisible="False" />
        </Border>

        <!-- Windows-style caption buttons (right side) -->
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Classes="caption-btn" Click="OnMinimize" ToolTip.Tip="Minimize">
            <Path Data="M0,0 L10,0" Stroke="{Binding $parent[Button].Foreground}"
                  StrokeThickness="1" Width="10" Height="1"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
          <Button Classes="caption-btn" Click="OnMaximize" ToolTip.Tip="Maximize">
            <Path Data="M0,0 L10,0 L10,10 L0,10 Z" Stroke="{Binding $parent[Button].Foreground}"
                  StrokeThickness="1" Fill="Transparent" Width="10" Height="10"
                  Stretch="Uniform"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
          <Button Classes="caption-btn close" Click="OnClose" ToolTip.Tip="Close">
            <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{Binding $parent[Button].Foreground}"
                  StrokeThickness="1" Width="10" Height="10"
                  Stretch="Uniform" StrokeLineCap="Round"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="210,*">
      <!-- Sidebar -->
      <Border Grid.Column="0" Background="#1a1a1a"
              BorderBrush="#262626" BorderThickness="0,0,1,0">
        <DockPanel>
          <!-- Brand row with border-bottom -->
          <Border DockPanel.Dock="Top" BorderBrush="#262626" BorderThickness="0,0,0,1"
                  Padding="16,14,16,12">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Kenshi Multi" FontSize="13" FontWeight="SemiBold" Foreground="#F0F0F0" />
              <TextBlock Grid.Column="1" Text="v0.2" FontSize="11" Foreground="#3a3a3a" VerticalAlignment="Center" />
            </Grid>
          </Border>

          <!-- Footer: identity card -->
          <Border DockPanel.Dock="Bottom" BorderBrush="#262626" BorderThickness="0,1,0,0"
                  Padding="12,10">
            <Border Background="#222222" BorderBrush="#262626" BorderThickness="1"
                    CornerRadius="5" Padding="10,8">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Steam avatar icon -->
                <Border Grid.Column="0" Width="22" Height="22" CornerRadius="4"
                        Background="#152030" Margin="0,0,8,0">
                  <Path Data="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29l3.32-6.86A3 3 0 0 1 12 9a3 3 0 0 1 3 3 3 3 0 0 1-3 3c-.22 0-.43-.02-.63-.07L8.1 18.82A10 10 0 0 0 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z"
                        Fill="#1b8ab0" Stretch="Uniform" Width="12" Height="12"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <!-- Name -->
                <TextBlock Grid.Column="1" Text="{Binding SteamName}" FontSize="11" FontWeight="Medium"
                           Foreground="#F0F0F0" VerticalAlignment="Center" />
                <!-- Steam label -->
                <TextBlock Grid.Column="2" Text="Steam" FontSize="10" Foreground="#1b8ab0"
                           VerticalAlignment="Center" />
              </Grid>
            </Border>
          </Border>

          <!-- Nav items -->
          <StackPanel Margin="0,6,0,0">
            <Panel>
              <Border IsVisible="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Play}"
                      Width="2" CornerRadius="0,1,1,0"
                      Background="#c8a052"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Stretch"
                      Margin="0,5,0,5" />
              <Button Classes="nav"
                      Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Play}"
                      Command="{Binding NavigateToCommand}"
                      CommandParameter="Play"
                      Padding="16,6">
                <StackPanel Orientation="Horizontal" Spacing="9">
                  <Path Data="M5,3 L19,12 L5,21 Z"
                        Fill="{Binding $parent[Button].Foreground}"
                        Stretch="Uniform" Width="13" Height="13"
                        VerticalAlignment="Center" />
                  <TextBlock Text="Play" FontSize="12"
                             Foreground="{Binding $parent[Button].Foreground}" />
                </StackPanel>
              </Button>
            </Panel>
            <Panel>
              <Border IsVisible="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Saves}"
                      Width="2" CornerRadius="0,1,1,0"
                      Background="#c8a052"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Stretch"
                      Margin="0,5,0,5" />
              <Button Classes="nav"
                      Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Saves}"
                      Command="{Binding NavigateToCommand}"
                      CommandParameter="Saves"
                      Padding="16,6">
                <StackPanel Orientation="Horizontal" Spacing="9">
                  <Path Data="M19,21 L5,21 C3.9,21 3,20.1 3,19 L3,5 C3,3.9 3.9,3 5,3 L16,3 L21,8 L21,19 C21,20.1 20.1,21 19,21 Z M17,21 L17,13 L7,13 L7,21 M7,3 L7,8 L15,8"
                        Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1.5"
                        Fill="Transparent"
                        Stretch="Uniform" Width="13" Height="13"
                        VerticalAlignment="Center" />
                  <TextBlock Text="Saves" FontSize="12"
                             Foreground="{Binding $parent[Button].Foreground}" />
                </StackPanel>
              </Button>
            </Panel>
            <Panel>
              <Border IsVisible="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Settings}"
                      Width="2" CornerRadius="0,1,1,0"
                      Background="#c8a052"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Stretch"
                      Margin="0,5,0,5" />
              <Button Classes="nav"
                      Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Settings}"
                      Command="{Binding NavigateToCommand}"
                      CommandParameter="Settings"
                      Padding="16,6">
                <StackPanel Orientation="Horizontal" Spacing="9">
                  <Path Data="M12,15 A3,3 0 1,1 12,9 A3,3 0 1,1 12,15 M19.4,15 a1.65,1.65 0 0,0 0.33,1.82 l0.06,0.06 a2,2 0 0,1 -2.83,2.83 l-0.06,-0.06 a1.65,1.65 0 0,0 -1.82,-0.33 a1.65,1.65 0 0,0 -1,1.51 L14,21 a2,2 0 0,1 -4,0 l0,-0.09 A1.65,1.65 0 0,0 9,19.4 a1.65,1.65 0 0,0 -1.82,0.33 l-0.06,0.06 a2,2 0 0,1 -2.83,-2.83 l0.06,-0.06 A1.65,1.65 0 0,0 4.68,15 a1.65,1.65 0 0,0 -1.51,-1 L3,14 a2,2 0 0,1 0,-4 l0.09,0 A1.65,1.65 0 0,0 4.6,9 a1.65,1.65 0 0,0 -0.33,-1.82 l-0.06,-0.06 a2,2 0 0,1 2.83,-2.83 l0.06,0.06 A1.65,1.65 0 0,0 9,4.68 a1.65,1.65 0 0,0 1,-1.51 L10,3 a2,2 0 0,1 4,0 l0,0.09 a1.65,1.65 0 0,0 1,1.51 a1.65,1.65 0 0,0 1.82,-0.33 l0.06,-0.06 a2,2 0 0,1 2.83,2.83 l-0.06,0.06 A1.65,1.65 0 0,0 19.4,9 a1.65,1.65 0 0,0 1.51,1 L21,10 a2,2 0 0,1 0,4 l-0.09,0 a1.65,1.65 0 0,0 -1.51,1 z"
                        Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1.5"
                        Fill="Transparent"
                        Stretch="Uniform" Width="13" Height="13"
                        VerticalAlignment="Center" />
                  <TextBlock Text="Settings" FontSize="12"
                             Foreground="{Binding $parent[Button].Foreground}" />
                </StackPanel>
              </Button>
            </Panel>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Main content area -->
      <Border Grid.Column="1" Background="#0F0F0F">
        <ContentControl Content="{Binding CurrentPage}" Margin="28,24,28,24" />
      </Border>
    </Grid>

    <!-- Join Modal Overlay (full-window) -->
    <Border Name="JoinOverlay" Background="#99000000" IsVisible="{Binding Play.IsJoinModalOpen}"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Border Background="#1a1a1a" CornerRadius="6" Width="300"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              BorderBrush="#303030" BorderThickness="1">
        <StackPanel>
          <Border BorderBrush="#262626" BorderThickness="0,0,0,1" Padding="16,14,16,12">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Join session" FontSize="13" FontWeight="Medium" Foreground="#F0F0F0" />
              <Button Grid.Column="1" Classes="modal-close" Content="&#x2715;"
                      Command="{Binding Play.CloseJoinModalCommand}" />
            </Grid>
          </Border>
          <StackPanel Margin="16">
            <Grid ColumnDefinitions="*,8,80">
              <StackPanel Grid.Column="0">
                <TextBlock Text="Host IP" FontSize="11" Foreground="#6b6b6b" Margin="0,0,0,5" />
                <TextBox Text="{Binding Play.JoinIP}" Watermark="192.168.x.x"
                         Background="#0f0f0f" FontSize="12" Padding="10,6" Height="30" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="Port" FontSize="11" Foreground="#6b6b6b" Margin="0,0,0,5" />
                <TextBox Text="{Binding Play.JoinPort}" Watermark="8080"
                         Background="#0f0f0f" FontSize="12" Padding="10,6" Height="30" />
              </StackPanel>
            </Grid>
            <TextBlock Text="Password" FontSize="11" Foreground="#6b6b6b" Margin="0,12,0,0" />
            <TextBlock Text="(optional)" FontSize="11" Foreground="#3a3a3a" Margin="4,0,0,5" />
            <TextBox Text="{Binding Play.JoinPassword}" Watermark="Leave empty if none"
                     PasswordChar="&#x2022;" Background="#0f0f0f" FontSize="12" Padding="10,6" Height="30" />
          </StackPanel>
          <Border BorderBrush="#262626" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right">
              <Button Classes="ghost" Height="28" Padding="14,0" FontSize="11"
                      Content="Cancel" VerticalContentAlignment="Center"
                      Command="{Binding Play.CloseJoinModalCommand}" />
              <Button Classes="accent" Height="28" Padding="14,0" FontSize="11"
                      Content="Connect" VerticalContentAlignment="Center"
                      Command="{Binding Play.ConnectCommand}"
                      IsEnabled="{Binding !Play.IsPlaying}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
    </Border>

    <!-- Save Picker Modal Overlay (full-window) -->
    <Border Name="SavePickerOverlay" Background="#99000000" IsVisible="{Binding Play.IsSavePickerOpen}"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Border Background="#1a1a1a" CornerRadius="6" Width="360" MaxHeight="440"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              BorderBrush="#303030" BorderThickness="1">
        <DockPanel>
          <Border DockPanel.Dock="Top" BorderBrush="#262626" BorderThickness="0,0,0,1" Padding="16,14,16,12">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Select a save" FontSize="13" FontWeight="Medium" Foreground="#F0F0F0" />
              <Button Grid.Column="1" Classes="modal-close" Content="&#x2715;"
                      Command="{Binding Play.CancelSavePickCommand}" />
            </Grid>
          </Border>
          <Border DockPanel.Dock="Bottom" BorderBrush="#262626" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right">
              <Button Classes="ghost" Height="28" Padding="14,0" FontSize="11"
                      Content="Cancel" VerticalContentAlignment="Center"
                      Command="{Binding Play.CancelSavePickCommand}" />
              <Button Classes="accent" Height="28" Padding="14,0" FontSize="11"
                      Content="Start" VerticalContentAlignment="Center"
                      Command="{Binding Play.ConfirmSavePickCommand}" />
            </StackPanel>
          </Border>
          <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,8,8,0">
            <StackPanel Spacing="4">
              <!-- "Create new" option at top -->
              <Border Background="{Binding Play.SelectedSaveForHost, Converter={x:Static ObjectConverters.IsNull}, ConverterParameter=#222222|#1a1a1a}"
                      CornerRadius="4" Padding="12,10" Cursor="Hand"
                      PointerPressed="SavePickerNewSession_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="+" FontSize="15" Foreground="#c8a052" VerticalAlignment="Center" />
                  <TextBlock Text="Create new session" FontSize="12" Foreground="#c8a052" VerticalAlignment="Center" />
                </StackPanel>
              </Border>
              <ItemsControl ItemsSource="{Binding Play.SavePickerSaves}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:SaveSummaryViewModel">
                    <Border Background="#1a1a1a" CornerRadius="4" Padding="12,8" Margin="0,0,0,0"
                            Cursor="Hand" Name="SavePickerItem"
                            PointerPressed="SavePickerItem_Click">
                      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                                   FontSize="12" FontWeight="Medium" Foreground="#F0F0F0" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LastModifiedText}"
                                   FontSize="10" Foreground="#3a3a3a" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Orientation="Horizontal" Spacing="10" Margin="0,3,0,0">
                          <TextBlock Text="{Binding PlayerCountText}" FontSize="10" Foreground="#6b6b6b" />
                          <TextBlock Text="{Binding SessionTimeText}" FontSize="10" Foreground="#6b6b6b" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Border>

    <!-- Host Modal Overlay (full-window) -->
    <Border Name="HostOverlay" Background="#99000000" IsVisible="{Binding Play.IsHostModalOpen}"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Border Background="#1a1a1a" CornerRadius="6" Width="300"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              BorderBrush="#303030" BorderThickness="1">
        <StackPanel>
          <Border BorderBrush="#262626" BorderThickness="0,0,0,1" Padding="16,14,16,12">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Host a server" FontSize="13" FontWeight="Medium" Foreground="#F0F0F0" />
              <Button Grid.Column="1" Classes="modal-close" Content="&#x2715;"
                      Command="{Binding Play.CloseHostModalCommand}" />
            </Grid>
          </Border>
          <StackPanel Margin="16">
            <Grid ColumnDefinitions="*,8,80">
              <StackPanel Grid.Column="0">
                <TextBlock Text="Port" FontSize="11" Foreground="#6b6b6b" Margin="0,0,0,5" />
                <TextBox Text="{Binding Play.HostPort}" Watermark="8080"
                         Background="#0f0f0f" FontSize="12" Padding="10,6" Height="30" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="Max players" FontSize="11" Foreground="#6b6b6b" Margin="0,0,0,5" />
                <TextBox Text="{Binding Play.HostMaxPlayers}" Watermark="4"
                         Background="#0f0f0f" FontSize="12" Padding="10,6" Height="30" />
              </StackPanel>
            </Grid>
            <TextBlock Text="Password" FontSize="11" Foreground="#6b6b6b" Margin="0,12,0,0" />
            <TextBlock Text="(optional)" FontSize="11" Foreground="#3a3a3a" Margin="4,0,0,5" />
            <TextBox Text="{Binding Play.HostPassword}" Watermark="Leave empty for open session"
                     PasswordChar="&#x2022;" Background="#0f0f0f" FontSize="12" Padding="10,6" Height="30" />
          </StackPanel>
          <Border BorderBrush="#262626" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right">
              <Button Classes="ghost" Height="28" Padding="14,0" FontSize="11"
                      Content="Cancel" VerticalContentAlignment="Center"
                      Command="{Binding Play.CloseHostModalCommand}" />
              <Button Classes="accent" Height="28" Padding="14,0" FontSize="11"
                      Content="Start server" VerticalContentAlignment="Center"
                      Command="{Binding Play.StartServerCommand}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</Window>
