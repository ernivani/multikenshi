<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KenshiLauncher.ViewModels"
             xmlns:views="using:KenshiLauncher.Views"
             x:Class="KenshiLauncher.Views.PlayView"
             x:DataType="vm:PlayViewModel">

  <UserControl.Resources>
    <views:TagBackgroundConverter x:Key="TagBgConv" />
    <views:TagForegroundConverter x:Key="TagFgConv" />
  </UserControl.Resources>

  <!-- Root Grid for modal overlay support -->
  <Grid>
    <!-- Main content -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
      <StackPanel Spacing="28">

        <!-- Version row -->
        <Grid ColumnDefinitions="*,136">
          <!-- Left: version + status -->
          <StackPanel Grid.Column="0">
            <StackPanel Orientation="Horizontal" Spacing="0">
              <TextBlock Text="0.2" FontSize="24" FontWeight="Light" Foreground="#F0F0F0"
                         VerticalAlignment="Bottom" />
              <TextBlock Text="alpha" FontSize="12" Foreground="#6b6b6b"
                         Margin="4,0,0,6" VerticalAlignment="Bottom" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,6,0,0">
              <Ellipse Name="StatusDot" Width="5" Height="5" VerticalAlignment="Center" />
              <TextBlock Name="StatusLabel" FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Name="StatusSubLabel" FontSize="10" Foreground="#3a3a3a" Margin="0,3,0,0" />
          </StackPanel>

          <!-- Right: action buttons stacked vertically -->
          <StackPanel Grid.Column="1" Spacing="6">
            <!-- Stop (playing) -->
            <Button Classes="danger" Height="32" HorizontalAlignment="Stretch"
                    Command="{Binding StopGameCommand}"
                    IsVisible="{Binding ShowStop}"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="M6,6 L18,6 L18,18 L6,18 Z"
                      Fill="#9a3a3a" Stretch="Uniform" Width="9" Height="9"
                      VerticalAlignment="Center" />
                <TextBlock Text="Stop" FontSize="12" FontWeight="SemiBold" Foreground="#9a3a3a"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <!-- Play (ready, not outdated, not playing) -->
            <Button Classes="accent" Height="32" HorizontalAlignment="Stretch"
                    Command="{Binding OpenJoinModalCommand}"
                    IsVisible="{Binding ShowPlay}"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="M5,3 L19,12 L5,21 Z"
                      Fill="#0F0F0F" Stretch="Uniform" Width="9" Height="9"
                      VerticalAlignment="Center" />
                <TextBlock Text="Play" FontSize="12" FontWeight="SemiBold" Foreground="#0F0F0F"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <!-- Update (outdated, not playing) -->
            <Button Classes="accent-outline" Height="32" HorizontalAlignment="Stretch"
                    Command="{Binding InstallDllCommand}"
                    IsVisible="{Binding ShowUpdate}"
                    IsEnabled="{Binding !IsInstalling}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Path Data="M12,2 L12,16 M5,9 L12,2 L19,9"
                      Stroke="#c8a052" StrokeThickness="1.8" Fill="Transparent"
                      Stretch="Uniform" Width="10" Height="10" VerticalAlignment="Center"
                      StrokeLineCap="Round" />
                <TextBlock Text="Update" FontSize="12" FontWeight="Medium" Foreground="#c8a052" />
              </StackPanel>
            </Button>
            <!-- Install (missing/corrupted, not playing) -->
            <Button Classes="accent-outline" Height="32" HorizontalAlignment="Stretch"
                    Command="{Binding InstallDllCommand}"
                    IsVisible="{Binding ShowInstall}"
                    IsEnabled="{Binding !IsInstalling}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Path Data="M8,17 L12,21 L16,17 M12,12 L12,21 M20.88,18.09 A5,5 0 0,0 18,9 L16.74,9 A8,8 0 1,0 3,16.29"
                      Stroke="#c8a052" StrokeThickness="1.8" Fill="Transparent"
                      Stretch="Uniform" Width="10" Height="10" VerticalAlignment="Center"
                      StrokeLineCap="Round" />
                <TextBlock Text="Install" FontSize="12" FontWeight="Medium" Foreground="#c8a052" />
              </StackPanel>
            </Button>
            <!-- Install feedback -->
            <TextBlock Text="{Binding InstallMessage}" FontSize="10" Foreground="#6b6b6b"
                       IsVisible="{Binding InstallMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       HorizontalAlignment="Center" Margin="0,2,0,0" />
            <!-- Host button -->
            <Button Name="HostButton" Classes="ghost" Height="30" HorizontalAlignment="Stretch"
                    Command="{Binding OpenHostModalCommand}"
                    IsEnabled="{Binding IsPlayReady}"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="M22,12 L18,12 L15,21 L9,3 L6,12 L2,12"
                      Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1.6" Fill="Transparent"
                      Stretch="Uniform" Width="9" Height="9" VerticalAlignment="Center"
                      StrokeLineCap="Round" />
                <TextBlock Text="Host a server" FontSize="12"
                           Foreground="{Binding $parent[Button].Foreground}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>

        <!-- Divider -->
        <Border Height="1" Background="#262626" />

        <!-- Changelog -->
        <ItemsControl ItemsSource="{Binding Changelog}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ChangelogEntry">
              <Border BorderBrush="#262626" BorderThickness="0,0,0,1" Padding="0,10,0,10">
                <Grid ColumnDefinitions="36,*">
                  <!-- Version column -->
                  <StackPanel Grid.Column="0" Margin="0,1,0,0">
                    <TextBlock Text="{Binding Version}" FontSize="11" FontWeight="Medium" Foreground="#6b6b6b" />
                    <TextBlock Text="{Binding Date}" FontSize="10" Foreground="#3a3a3a" Margin="0,2,0,0" />
                  </StackPanel>
                  <!-- Lines column -->
                  <ItemsControl Grid.Column="1" ItemsSource="{Binding Lines}" Margin="16,0,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ChangelogLine">
                        <StackPanel Orientation="Horizontal" Spacing="7" Margin="0,2.5">
                          <Border Background="{Binding Tag, Converter={StaticResource TagBgConv}}"
                                  CornerRadius="3" Padding="5,1" MinWidth="28"
                                  HorizontalAlignment="Left">
                            <TextBlock Text="{Binding Tag}" FontSize="9" FontWeight="Medium"
                                       Foreground="{Binding Tag, Converter={StaticResource TagFgConv}}"
                                       HorizontalAlignment="Center" />
                          </Border>
                          <TextBlock Text="{Binding Text}" FontSize="11" Foreground="#6b6b6b"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

  </Grid>
</UserControl>
